{
    "name": "@themeparks/typelib",
    "version": "1.1.3",
    "description": "TypeScript definition system and type generator for ThemeParks.wiki",
    "exports": {
        ".": "./src/index.ts",
        "./generate": "./src/generate_types.ts",
        "./hash": "./src/hash.ts"
    },
    "publish": {
        "include": [
            "src/**/*.ts",
            "typesrc/**/*.json",
            "README.md"
        ],
        "exclude": [
            "src/__tests__"
        ]
    }
}
